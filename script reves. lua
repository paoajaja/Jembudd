-- ==================================================
-- REWIND FUNCTION (GERAK MUNDUR KAYA VIDEO)
-- ==================================================
local function rewindRevive()
    -- Cegah spam
    if settings.isRewinding then 
        statusText.Text = "⚠️ Sedang rewind..."
        return 
    end
    
    local character = player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local root = character:FindFirstChild("HumanoidRootPart")
    
    if not root or not humanoid or humanoid.Health <= 0 then return end
    
    settings.isRewinding = true
    statusText.Text = "🌀 REWINDING..."
    reviveButton.Text = "⏳..."
    reviveButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    
    -- Simpan posisi awal
    local startY = root.Position.Y
    local targetY = settings.reviveHeight
    local distance = targetY - startY
    
    -- Matikan auto rotate selama rewind
    humanoid.AutoRotate = false
    
    -- Efek visual mulai
    for i = 1, 3 do
        root.Transparency = 0.5
        task.wait(0.03)
        root.Transparency = 0
        task.wait(0.03)
    end
    
    -- REWIND EFFECT - GERAK MUNDUR
    local steps = 30
    for i = 1, steps do
        if not root or not humanoid or humanoid.Health <= 0 then break end
        
        -- Hitung posisi baru (mundur)
        local progress = i / steps
        local newY = startY + (distance * progress)
        
        -- Set posisi
        root.CFrame = CFrame.new(root.Position.X, newY, root.Position.Z)
        
        -- Efek rotasi (berputar kayak rewind)
        root.Orientation = Vector3.new(0, root.Orientation.Y - 15, 0)
        
        -- Efek transparan (efek ghost)
        root.Transparency = 0.3 + (0.5 * math.sin(i * 0.5))
        
        task.wait(0.03)  -- Delay kecil biar keliatan geraknya
    end
    
    -- Pastikan sampai di target
    if root then
        root.CFrame = CFrame.new(root.Position.X, targetY, root.Position.Z)
        root.Transparency = 0
        root.Orientation = Vector3.new(0, root.Orientation.Y, 0)
    end
    
    -- Balikin settings
    if humanoid then
        humanoid.AutoRotate = true
    end
    
    -- Efek selesai
    for i = 1, 5 do
        if root then
            root.Transparency = 0.3
            task.wait(0.05)
            root.Transparency = 0
            task.wait(0.05)
        end
    end
    
    -- Selesai
    settings.isRewinding = false
    statusText.Text = "✅ Rewind selesai!"
    reviveButton.Text = "🌀 REWIND"
    reviveButton.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
    
    -- Notifikasi
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "ZONE XD REWIND";
        Text = "✅ Kamu sudah direwind!";
        Duration = 2;
    })
end

