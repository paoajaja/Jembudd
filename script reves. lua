-- MONITOR JATUH (BUAT UPDATE STATUS)
-- ==================================================
RunService.Heartbeat:Connect(function()
    local character = player.Character
    if character then
        local root = character:FindFirstChild("HumanoidRootPart")
        if root then
            -- Update status berdasarkan posisi
            if root.Position.Y < 10 then
                statusText.Text = "⚠️ Kamu di bawah! Tekan REWIND"
                statusText.TextColor3 = Color3.fromRGB(255, 100, 100)
                reviveButton.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
            else
                if not settings.isRewinding then
                    statusText.Text = "✨ Aman. Tekan buat rewind"
                    statusText.TextColor3 = Color3.fromRGB(150, 150, 150)
                    reviveButton.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
                end
            end
        end
    end
end)

